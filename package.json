{
  "name": "directus-extension-reply-to-mail",
  "description": "Custom operation to send emails with reply-to field set. It uses the Directus Nodemailer service and extends it with a replyTo option.",
  "icon": "reply",
  "author": {
    "email": "dev@harke.me",
    "name": "lkshrk"
  },
  "license": "MIT",
  "version": "1.2.1",
  "keywords": [
    "directus",
    "directus-extension",
    "directus-extension-mail",
    "directus-extension-operation",
    "directus-extension-reply-to-mail",
    "directus-operation",
    "directus-mail",
    "directus-reply-to-mail"
  ],
  "homepage": "https://github.com/lkshrk/directus-extension-reply-to-mail#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lkshrk/directus-extension-reply-to-mail.git"
  },
  "bugs": {
    "url": "https://github.com/lkshrk/directus-extension-reply-to-mail/issues"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "directus:extension": {
    "type": "operation",
    "path": {
      "app": "dist/app.js",
      "api": "dist/api.js"
    },
    "source": {
      "app": "src/app.ts",
      "api": "src/api.ts"
    },
    "host": "^11.10.0"
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify",
    "link": "directus-extension link",
    "prepare": "pnpm run build",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage"
  },
  "dependencies": {
    "marked": "18.0.0",
    "sanitize-html": "2.17.2"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "17.1.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/nodemailer": "8.0.0",
    "jest": "^30.0.0",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.1.5",
    "typescript": "^6.0.2",
    "vue": "^3.5.25"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver",
      "vue-demi"
    ]
  }
}
